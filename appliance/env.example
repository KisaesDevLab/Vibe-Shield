# Vibe Shield — appliance environment variables.
#
# Copy to your appliance .env (e.g., /opt/vibe/appliance/.env) and
# populate. Required vars cause the gateway to refuse to start with a
# zod-validated error.
#
# Secret handling:
#   - This file MUST NOT be committed when populated.
#   - Use the appliance's secret manager to populate ANTHROPIC_API_KEY,
#     VS_KEK, VIBE_SHIELD_ADMIN_KEY at runtime — don't put them on disk.
#   - VS_KEK is read once at boot, then deleted from process.env
#     (v1.1.3 §review S3 hardening) — operators should still rotate KEK
#     periodically via `make rotate-kek-apply`.

# ============================================================
# REQUIRED — gateway refuses to start without these
# ============================================================

# Anthropic commercial API key. Consumer (Free/Pro/Max) keys are
# probed + rejected at startup. Source: console.anthropic.com.
ANTHROPIC_API_KEY=

# AES-256-GCM key-encryption key. Generate exactly once per appliance:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Store in the appliance secret manager. Rotation procedure:
#   make rotate-kek-dry    # dry-run; counts rows that will be re-wrapped
#   make rotate-kek-apply  # applies under transaction
VS_KEK=

# Postgres DSN. Use the appliance's existing Postgres; Vibe Shield
# creates its own tables under `vs_*` prefix in the database.
VIBE_SHIELD_DATABASE_URL=postgres://vibe:vibe@vibe-postgres:5432/vibe_appliance

# Redis URL — Vibe Shield's canonical DB index is /5 (allocated in the
# Vibe-Appliance app catalog: 0=tb, 1=mybooks, 2=calc, 3=tax-research,
# 4=payroll, 5=shield, 6=tx-converter). If you reuse this fragment for a
# non-appliance Redis instance, /5 still works — index choice is local.
VIBE_SHIELD_REDIS_URL=redis://vibe-redis:6379/5

# Admin API key for /v1/admin/* routes (X-Admin-Key header). Without
# this set, the admin API refuses all requests. Generate:
#   echo "vs-admin-$(openssl rand -hex 16)"
VIBE_SHIELD_ADMIN_KEY=

# ============================================================
# OPTIONAL — sensible defaults shipped in the gateway
# ============================================================

# Image tag to pull from GHCR. Pin a release tag; never `:latest`.
# Appliance update flow controls when this rolls forward.
VIBE_SHIELD_VERSION=v1.6.0

# Admin SPA base path. Defaults to `/`. Set to e.g. `/shield/` when a
# reverse proxy in front of the admin container mounts the UI under a
# path prefix and strips that prefix before hitting nginx. Must end
# with a slash. The admin nginx entrypoint shim reads this value at
# container start and sed-substitutes the bundle's sentinel.
VIBE_SHIELD_ADMIN_BASE_PATH=/

# Toggle the gateway entrypoint's auto-migrate step. `true` (default)
# runs `node dist/migrate.js` to completion before serving — idempotent
# via Drizzle's __drizzle_migrations table. Set to `false` if you
# prefer to run migrations as a separate one-shot job for blue-green
# schema rollout control.
VIBE_SHIELD_MIGRATIONS_AUTO=true

# Existing Docker network the appliance services share.
VIBE_NETWORK_NAME=vibe-network

# Anthropic Zero Data Retention. Requires the ZDR addendum signed on
# the Anthropic account; the header alone does NOT activate ZDR.
VIBE_SHIELD_ZDR_ENABLED=false

# Per-(tenant, app) request cap per minute. Tune via per-tenant policy
# overrides — this is the default ceiling.
VIBE_SHIELD_RATE_LIMIT=60

# Per-tenant monthly spend cap in micro-dollars (USD * 1e6).
# 500_000_000 = $500/month. Tune via policy.
VIBE_SHIELD_SPEND_CAP=500000000

# Phase 25 G2.8 — per-tenant per-minute spend rate cap in micro-dollars.
# Distinct from the monthly cap above: this stops the *rate* of spend so
# a runaway worker can't burn through a month of budget in a few minutes.
# Soft-warn at 80%, 429 + Retry-After at 100%. 0 disables. Default
# 100_000_000 = $100/min.
VIBE_SHIELD_SPEND_RATE_PER_MINUTE=100000000

# Phase 25 G2.6 — versioned prompt template directory. Operators who
# want to expose custom prompts to the Phase 28 internal API mount a
# directory of *.md templates here. Each file's SHA-256 is recorded in
# the audit row of every Claude call that uses it. When unset the
# registry stays empty (no consumer yet — Phase 28 lights it up).
# See apps/gateway/src/prompts/README.md for the file format.
VIBE_SHIELD_PROMPTS_DIR=

# Phase 17 — Redact module per-upload byte cap. v1.5 raises the
# default from 25 MB → 50 MB to accommodate scanned multi-page PDFs
# (bank statements, 1099/W-2 packs). Set lower for tighter abuse
# protection; larger uploads return 413.
VIBE_SHIELD_REDACT_MAX_UPLOAD_BYTES=52428800

# Phase 17 v1.5 — Artifact-purge cron interval (ms). The cron walks
# completed-and-past-expiry jobs hourly and removes both the on-disk
# directory and the DB row. Failed jobs are kept for diagnosis. 0
# disables (operator does cleanup manually).
VIBE_SHIELD_REDACT_PURGE_INTERVAL_MS=3600000

# Periodic Anthropic key re-probe interval (ms). 0 disables; default
# 15 min. Failures log warn + never crash; the next /v1/messages call
# fails-closed via the existing 401/503 path.
VIBE_SHIELD_REPROBE_INTERVAL_MS=900000

# Max request body size (bytes). Anthropic accepts up to 256 KB on
# /v1/messages; default 1 MB here gives headroom for large tool
# payloads. Tune down for tighter abuse protection.
VIBE_SHIELD_MAX_REQUEST_BYTES=1048576

# Session idle TTL (minutes). After this, the token vault discards
# the per-session DEK and stored tokens become unrecoverable. Shorter
# = tighter security; longer = better re-id continuity across requests.
VIBE_SHIELD_SESSION_TTL_MINUTES=60

# Pino log level. fatal | error | warn | info | debug | trace | silent.
VIBE_SHIELD_LOG_LEVEL=info

# Timezone for log timestamps. Defaults to UTC.
TZ=UTC

# Appliance domain (for Caddy reverse-proxy site names).
# Caddy uses this in shield.{$VIBE_DOMAIN} + gateway.shield.{$VIBE_DOMAIN}.
VIBE_DOMAIN=firm.local

# ============================================================
# OPTIONAL — Phase 24 magic-link sign-in
# ============================================================
# When SMTP_HOST is unset, /api/auth/request-link returns 501 and
# operators continue to use VIBE_SHIELD_ADMIN_KEY (X-Admin-Key) only.
# Set the variables below to enable email-based sign-in.

# Public origin where the admin SPA is reachable. Magic-link URLs in
# email are built off this — must include the scheme.
VIBE_SHIELD_PUBLIC_URL=https://shield.firm.local

# SMTP relay for magic-link emails. The gateway verifies the
# connection at startup and logs a warning if it fails; sign-in
# attempts will surface the failure at send time.
VIBE_SHIELD_SMTP_HOST=
VIBE_SHIELD_SMTP_PORT=587
VIBE_SHIELD_SMTP_USER=
VIBE_SHIELD_SMTP_PASSWORD=
VIBE_SHIELD_SMTP_FROM=vibe-shield@firm.local
VIBE_SHIELD_SMTP_TLS=true

# On first boot, if the users table is empty AND this is set, this
# email is created as the bootstrap org_admin with admin role on
# every module. Idempotent — skipped if any user already exists.
VIBE_SHIELD_BOOTSTRAP_ADMIN_EMAIL=

# Sliding session idle TTL (minutes). Default 1440 (24h).
VIBE_SHIELD_SESSION_IDLE_TTL_MINUTES=1440

# Magic-link single-use token TTL (minutes). Default 15.
VIBE_SHIELD_MAGIC_LINK_TTL_MINUTES=15
