{
  "name": "@kisaesdevlab/vibe-shield-schema",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Drizzle schema + AES-256-GCM crypto helpers for the Vibe Shield token vault.",
  "license": "SEE LICENSE IN ../../LICENSE",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js"
    },
    "./db/migrate": {
      "types": "./dist/db/migrate.d.ts",
      "import": "./dist/db/migrate.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.scripts.json",
    "test": "vitest run",
    "lint": "eslint .",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "rotate-kek": "tsx scripts/rotate-kek.ts",
    "migrate": "tsx scripts/migrate.ts",
    "audit-digest": "tsx scripts/write-audit-digest.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
